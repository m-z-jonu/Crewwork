# CrewWork Configuration
# Copy this file to .env.local and fill in your values
# Or use the setup wizard at http://localhost:3000/setup

# ---- Supabase (required) ----
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---- AI Agent (optional) ----
# DeepSeek API key for the AI assistant
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL_CHAT=deepseek-v4-flash
DEEPSEEK_MODEL_REASON=deepseek-v4-flash
# UUID for the AI bot profile in the profiles table
AI_AGENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AI_AGENT_ID=00000000-0000-0000-0000-000000000000
